                        "title": "Task Progress"
                    },
                    "date_created": {
                        "type": "string",
                        "format": "date-time",
                        "title": "Date Created"
                    },
                    "date_updated": {
                        "type": "string",
                        "format": "date-time",
                        "title": "Date Updated"
